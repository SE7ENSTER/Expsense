rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function hasProfile() {
      return signedIn()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function myRole() {
      return hasProfile()
        ? get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role
        : 'user';
    }

    function isDisabled() {
      return hasProfile()
        && (
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.active == false
          || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'disabled'
        );
    }

    function isActiveUser() {
      return signedIn() && !isDisabled();
    }

    function isAdmin() {
      return isActiveUser() && myRole() == 'admin';
    }

    function isManager() {
      return isActiveUser() && myRole() == 'manager';
    }

    function isFinance() {
      return isActiveUser() && myRole() == 'finance';
    }

    function isBackOffice() {
      return isAdmin() || isManager() || isFinance();
    }

    match /users/{userId} {
      allow create: if signedIn()
        && (
          userId == request.auth.uid
          || isAdmin()
        );

      allow read: if signedIn()
        && (
          userId == request.auth.uid
          || isBackOffice()
        );

      allow update, delete: if isAdmin();
    }

    match /budgets/{budgetId} {
      allow read: if isActiveUser();
      allow create, update, delete: if isAdmin() || isFinance();
    }

    match /approvalLogs/{logId} {
      allow read: if isBackOffice();
      allow create: if isBackOffice();
      allow update, delete: if false;
    }

    match /paymentLogs/{logId} {
      allow read: if isAdmin() || isFinance();
      allow create: if isAdmin() || isFinance();
      allow update, delete: if false;
    }

    match /expenseReports/{reportId} {
      allow create: if isActiveUser()
        && request.resource.data.userId == request.auth.uid;

      allow read: if isActiveUser()
        && (
          resource.data.userId == request.auth.uid
          || isAdmin()
          || (
            isManager()
            && resource.data.status in [
              'Submitted',
              'Manager Approved',
              'Rejected',
              'Revision Requested'
            ]
          )
          || (
            isFinance()
            && resource.data.status in [
              'Manager Approved',
              'Finance Processing',
              'Reimbursement Processing',
              'Reimbursed',
              'Closed'
            ]
          )
        );

      allow update: if isActiveUser()
        && (
          isAdmin()
          || resource.data.userId == request.auth.uid
          || (
            isManager()
            && resource.data.status == 'Submitted'
          )
          || (
            isFinance()
            && resource.data.status in [
              'Manager Approved',
              'Finance Processing',
              'Reimbursement Processing'
            ]
          )
        );

      allow delete: if isAdmin();
    }
  }
}
